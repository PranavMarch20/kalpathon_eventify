PORT=5000
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/eventify
JWT_SECRET=replace_with_a_strong_jwt_secret

EMAIL=your-email@gmail.com
EMAIL_PASSWORD=your-gmail-app-password

IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id

FRONTEND_URL=http://localhost:5173


// change the above values with your actual credentials and settings before running the application. and also the name of the .env file should be .env (not .env.example) when you create it in the backend folder.